# ── Django ──────────────────────────────────────────────────────
# Genera con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=CHANGE-ME-50-RANDOM-CHARS

# 1 = modo desarrollo (NO usar en prod)
DJANGO_DEBUG=0

# CSV de hosts permitidos (Host header). Sin espacios.
DJANGO_ALLOWED_HOSTS=baluhome.example.com,127.0.0.1,localhost

# ── Rutas de datos ──────────────────────────────────────────────
# Deben existir y ser escribibles por el usuario del servicio (www-data).
BALUHOME_DATA_ROOT=/var/www/balusong/data
BALUHOME_VAULT_ROOT=/var/www/balusong/data/vault
BALUHOME_UPLOADS_ROOT=/var/www/balusong/uploads
BALUHOME_VIDEOS_ROOT=/var/www/balusong/uploads/videos
# Directorio dedicado a avatares de usuarios. Servido por nginx en
# /static/avatars/ vía un location específico (NO está en collectstatic
# para que `manage.py collectstatic --clear` no los borre).
BALUHOME_AVATARS_ROOT=/var/www/balusong/avatars

# Donde collectstatic vuelca los estáticos (WhiteNoise). Por defecto
# BASE_DIR/static_collected si no se especifica.
# STATIC_ROOT=/var/www/balusong/django_app/static_collected

# ── Base de datos ────────────────────────────────────────────────
DB_NAME=baluhome
DB_USER=baluhome
DB_PASSWORD=CHANGE-ME
DB_HOST=127.0.0.1
DB_PORT=3306

# ── Web Push (VAPID) ─────────────────────────────────────────────
# Genera con `vapid --gen` o equivalente.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@example.com
